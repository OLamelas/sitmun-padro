# ============================================================
# PADRO - Archivo de variables de entorno de ejemplo
# Copia este archivo a .env y rellena los valores reales.
# ============================================================

# ------------------------------------------------------------
# Puerto expuesto en el host para acceder a la API REST
# ------------------------------------------------------------
HOST_PORT=9090

# ------------------------------------------------------------
# Seguridad básica (Spring Security - Basic Auth)
# ------------------------------------------------------------
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# ------------------------------------------------------------
# Secreto compartido para el filtro de peticiones API
# ------------------------------------------------------------
API_SHARED_SECRET=my-secret-token

# ------------------------------------------------------------
# Métodos HTTP permitidos
# Solo GET para modo lectura (por defecto).
# Para habilitar escritura: GET,PUT,POST
# ------------------------------------------------------------
API_ALLOWED_METHODS=GET

# ------------------------------------------------------------
# Conexión a base de datos (SITMUN / Padrón)
# ------------------------------------------------------------
DB_URL=jdbc:oracle:thin:@//host:1521/servicio
# DB_URL=jdbc:postgresql://host:5432/nombre_bd
DB_USERNAME=db_user
DB_PASSWORD=db_password

# ------------------------------------------------------------
# Servicio SOAP de Aytos (padrón municipal)
# ------------------------------------------------------------
AYTOS_SOAP_URL=http://host/servicio/ws
AYTOS_USERNAME=aytos_user
AYTOS_PASSWORD=aytos_password
# Clave pública usada para cifrar credenciales Aytos
AYTOS_PUB_KEY=base64_encoded_public_key

# ------------------------------------------------------------
# Servicio REST de referencias catastrales (Aytos)
# ------------------------------------------------------------
AYTOS_REFCAT_URL=http://host/refcat/endpoint

# ------------------------------------------------------------
# Servicio SOAP de Tributos
# ------------------------------------------------------------
TRIBUTES_SOAP_URL=http://host/tributs/ws

# Mensaje SOAP para consulta de tributos.
# Los placeholders {municipio} y {ref_cad} se sustituyen en tiempo de ejecución.
# Incluir en una sola línea sin saltos de línea.
TRIBUTES_SOAP_MSG=<soap:Envelope xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/"><soap:Body><Tributs xmlns="http://tempuri.org/"><IDEntitat>{municipio}</IDEntitat><IDUsuari>mtuson</IDUsuari><refCadastral>{ref_cad}</refCadastral></Tributs></soap:Body></soap:Envelope>

# ------------------------------------------------------------
# Transformaciones de municipios
# JSON: mapeo de código INE corto → código completo SITMUN
# ------------------------------------------------------------
TRANSFORMATIONS_MUNICIPALITIES={"25110":"2511090004"}

# ------------------------------------------------------------
# Perfil de Spring (prod | dev)
# ------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod

